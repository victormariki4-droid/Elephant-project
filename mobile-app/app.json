{
  "expo": {
    "name": "HEC Alert Center",
    "slug": "hec-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "hec-tracker",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f4f8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hec.tracker",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HEC Alert Center needs your location to tag alert reports with GPS coordinates.",
        "NSMicrophoneUsageDescription": "HEC Alert Center needs microphone access for voice-based incident reports.",
        "NSCameraUsageDescription": "HEC Alert Center needs camera access for photo evidence in reports.",
        "NSPhotoLibraryUsageDescription": "HEC Alert Center needs photo library access for uploading evidence images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0f4f8"
      },
      "package": "com.hec.tracker",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-av",
        {
          "microphonePermission": "Allow HEC Alert Center to access your microphone for voice reports."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HEC Alert Center to access your photos for evidence upload.",
          "cameraPermission": "Allow HEC Alert Center to use camera for photo evidence."
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20"
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3c32883e-bf5e-4634-8cc6-d06cdfbe26d3"
      }
    }
  }
}
